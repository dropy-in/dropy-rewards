-  border-radius: 2px;
-  margin: 0 auto 16px;
+  background: rgba(255, 255, 255, 0.5);
+  border-radius: 99px;
+  z-index: 2;
 }
 @media (min-width: 768px) {
   .dei-handle { display: none; }
