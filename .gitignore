node_modules

# Local pnpm lockfile — pnpm is used locally for `shopify app deploy`, but Vercel must
# keep building the server with npm via the committed package-lock.json. Ignoring this
# prevents an accidental commit from flipping Vercel's package-manager detection.
pnpm-lock.yaml

# macOS
.DS_Store

/.cache
/build
/app/build
/public/build/
/public/_dev
/app/public/build
/prisma/dev.sqlite
/prisma/dev.sqlite-journal
database.sqlite

.env
.env.*





/extensions/*/dist

# Ignore shopify files created during app dev
.shopify/*
.shopify.lock

# Hide files auto-generated by react router
.react-router/.vercel/ 

.react-router/
.vercel/
