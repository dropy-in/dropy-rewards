+@media (prefers-reduced-motion: reduce) {
+  .dei-overlay, .dei-popup { transition: opacity 0.2s ease; }
+  .dei-popup { transform: none; }
+  .dei-popup.dei-show { transform: none; }
+  @media (min-width: 768px) {
+    .dei-popup { transform: translate(-50%, -50%); }
+    .dei-popup.dei-show { transform: translate(-50%, -50%); }
+  }
+}
+
+/* Gradient header band — the brand moment */
+.dei-header {
+  position: relative;
+  background:
+    radial-gradient(120% 140% at 85% 0%, rgba(255, 237, 213, 0.45) 0%, transparent 55%),
+    linear-gradient(135deg, #fb923c 0%, #f97316 45%, #ea580c 100%);
+  padding: 26px 24px 22px;
+  text-align: center;
+  overflow: hidden;
+}
+/* subtle shine sweep */
+.dei-header::after {
+  content: "";
+  position: absolute;
+  top: -60%;
+  left: -20%;
+  width: 60%;
+  height: 220%;
+  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
+  transform: rotate(18deg);
+  animation: dei-shine 4.5s ease-in-out 0.6s infinite;
+}
+@keyframes dei-shine {
+  0% { left: -30%; }
+  35%, 100% { left: 130%; }
+}
+@media (prefers-reduced-motion: reduce) {
+  .dei-header::after { animation: none; display: none; }
+}
+
+.dei-eyebrow {
+  display: inline-block;
+  font-size: 11px;
+  font-weight: 600;
+  letter-spacing: 0.12em;
+  text-transform: uppercase;
+  color: rgba(255, 255, 255, 0.85);
+  margin-bottom: 6px;
+}
+
+.dei-heading {
+  position: relative;
+  font-size: 21px;
+  font-weight: 700;
+  line-height: 1.25;
+  color: #fff;
+  margin: 0;
+  text-shadow: 0 1px 2px rgba(124, 45, 18, 0.25);
+}
+
+.dei-body {
+  font-size: 14.5px;
+  color: #57534e;
+  margin: 0 0 16px;
+  line-height: 1.55;
+  text-align: center;
+}
+
+/* Body content wrapper */
+.dei-content {
+  padding: 20px 24px 22px;
+}
+
 /* Mobile grab handle */
 .dei-handle {
-  width: 36px;
